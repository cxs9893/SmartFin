FINQA_APP_NAME=SmartFin
FINQA_WORKSPACE_DIR=.finqa
FINQA_DATA_DIR=data
FINQA_INDEX_DIR=.finqa/index

# llm provider (local, low-resource first)
FINQA_LLM_PROVIDER=modelscope_local
FINQA_LLM_MODEL=models/Qwen2___5-0___5B-Instruct
FINQA_LLM_DEVICE=auto
FINQA_LLM_MAX_NEW_TOKENS=192
FINQA_LLM_LOCAL_FILES_ONLY=true

# embedding provider: bge | hash
FINQA_EMBEDDING_PROVIDER=bge
FINQA_EMBEDDING_BATCH_SIZE=32
FINQA_EMBEDDING_TIMEOUT_SECONDS=30

# bge model (local self-hosted runtime)
FINQA_EMBEDDING_BGE_MODEL=models/bge-base-zh-v1.5
FINQA_EMBEDDING_BGE_DIM=768
FINQA_EMBEDDING_BGE_DEVICE=cpu
FINQA_EMBEDDING_BGE_LOCAL_FILES_ONLY=true
FINQA_EMBEDDING_BGE_TRUST_REMOTE_CODE=false

# hash fallback provider
FINQA_EMBEDDING_HASH_DIM=256
